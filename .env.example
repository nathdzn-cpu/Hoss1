# Supabase (client-side, exposed in bundle — use the anon/publishable key only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# SMTP (server-side only, used by /api/send-email)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=user@example.com
SMTP_PASSWORD=your-smtp-password

# Comma-separated list of origins allowed to POST to /api/send-email
ALLOWED_ORIGINS=https://thehoss.co.uk,https://www.thehoss.co.uk
